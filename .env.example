# Copy this file to .env and fill in values.
# Prisma reads DATABASE_URL via prisma.config.ts (dotenv/config), not automatically.
#
# All keys below are OPTIONAL for local development:
# - Job Search (Adzuna/Reed) falls back to a fixed set of sample listings
#   when NODE_ENV=development and neither provider has credentials — see
#   resolveDefaultJobProviders() in src/lib/di/container.ts. Outside
#   development, missing job-provider keys mean search returns zero
#   results (the UI will say so) rather than silently using sample data.
# - Match Score / Cover Letter / CV Suggestions require OPENAI_API_KEY in
#   every environment — there's no mock fallback for these; without it
#   they return a clear "AI features are not configured" error.
# See README.md's "Using real APIs vs. mock fallback" section for details.

DATABASE_URL="file:./dev.db"

# Adzuna Job Search API — https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Adzuna country code; defaults to "gb" if unset.
ADZUNA_COUNTRY=gb

# Reed Jobseeker API — https://www.reed.co.uk/developers/jobseeker
REED_API_KEY=

# OpenAI API — https://platform.openai.com/
OPENAI_API_KEY=
# Chat completion model; defaults to "gpt-4o-mini" if unset. Whatever model
# you set here is passed straight through — the app never overrides
# model-specific parameters (like temperature) that vary between models.
OPENAI_MODEL=gpt-4o-mini
